# Use library(mvtnorm) first for 3-D Multivariate Normal Density
library(mvtnorm)
mu<-matrix(c(0.5, -0.2, 0.1),nrow=1) # note matrix
cov<-matrix(data=c(
 1.0, 0.5, 0.2,
 0.5, 1.2, 0.3,
